# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# sensitive / non-code documents
/docs/
scripts/poem-chunks.json

# Corpus backups (timestamped .json.gz snapshots from `npm run backup:corpus`).
# Local safety net for the destructive seed; too large + regenerable for git.
/backups/

# Claude Code internal state (per-session locks, etc.)
/.claude/

# one-off local dev provisioning scripts (contain hardcoded test creds)
/scripts/setup-e2e-user.ts

# Per-session working log: public version (SCRATCHPAD.md) IS committed for
# durability + portfolio. Private version (.local suffix, mirrors Next.js
# `.env.local` convention) holds roadmap / soft state — never committed.
# See CLAUDE.md "Working conventions".
/SCRATCHPAD.local.md

# Eval harness per-run results (timestamped, ~40KB each, would balloon git
# history). The fixtures and script are committed; outputs are local-only.
/fixtures/eval-results-*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
# Note: next-env.d.ts is auto-generated by Next.js, should exist locally but not be committed
